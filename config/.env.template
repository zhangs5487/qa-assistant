# =============================================================================
# QA Assistant — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored; NEVER commit secrets.
# =============================================================================

# ---- Environment ----
ENVIRONMENT=dev
DEBUG=false

# ---- Paths ----
DATA_DIR=./data

# ---- Crawler ----
CRAWL_DELAY=1.0
CRAWL_MAX_PAGES=1000
CONCURRENT_REQUESTS=4

# ---- Auth (for cqaip.cn protected APIs) ----
# Login to cqaip.cn, then paste your casdoor_session_id cookie here
# CASDOOR_SESSION_ID=

# ---- Milvus (Vector DB) ----
# Dev: ./data/milvus.db — Milvus Lite embedded (no server needed)
# Prod: http://milvus:19530 — standalone Milvus server
MILVUS_DB_PATH=./data/milvus.db
MILVUS_QA_COLLECTION=qa_pairs
MILVUS_CHUNK_COLLECTION=doc_chunks

# ---- Chunking ----
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ---- Retrieval ----
RETRIEVAL_TOP_K=10
RRF_K=60
QA_MATCH_THRESHOLD=0.85

# ---- Embedding ----
# local_bge:   BGE-M3 本地模型 (推荐，零成本，~2.2GB)
# api:         共用 CHAT_API_BASE_URL/CHAT_API_KEY，调用兼容OpenAI的Embedding API
# openai:      OpenAI text-embedding-3-small API
# local_qwen3: Qwen3-Embedding 本地模型
# 本地模式时 EMBEDDING_MODEL=模型路径; API模式时 EMBEDDING_MODEL=模型名(如text-embedding-3-small)
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=./models/bge-m3
EMBEDDING_DIMENSIONS=1024

# ---- Reranker (Cross-encoder 重排序) ----
# local_bge: BGE-Reranker-v2-m3 本地模型 (约2.1GB, 需GPU/内存)
# none:      关闭 reranker (API部署推荐，省资源)
RERANKER_PROVIDER=local_bge
RERANKER_MODEL=./models/bge-reranker-v2-m3
RERANKER_TOP_K=5
RERANKER_CANDIDATES=15

# ---- LLM / Chat ----
# 通用 API 模式 (推荐): provider=api, 填 chat_api_base_url + chat_api_key + chat_model
# 本地模式: provider=local_llm, 填 local_llm_path
# 保留兼容: openai
CHAT_PROVIDER=api
CHAT_MODEL=deepseek-v4-flash
CHAT_API_BASE_URL=
CHAT_API_KEY=

# 本地 LLM (CHAT_PROVIDER=local_llm 时启用)
# LOCAL_LLM_PATH=./models/qwen3-1.7b

# ---- API Keys (备用/兼容) ----
OPENAI_API_KEY=

# ---- API Fetcher ----
API_BASE_URL=https://cqaip.cn
REQUEST_TIMEOUT=30
REQUEST_RETRIES=3

# ---- QA Augmentation ----
QA_AUGMENTATION_ENABLED=true
QA_AUGMENTATION_VARIANTS=3

# ---- Logging ----
LOG_LEVEL=INFO
